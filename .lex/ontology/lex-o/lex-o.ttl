@prefix lex-o: <https://repolex.ai/ontology/lex-upper/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# LEX UPPER ONTOLOGY (lex-o:)
# =============================================================================
# Shared starting vocabulary for every git-lex knowledge repo. Provides the
# common ground that makes independent repos' ontologies interoperable.
#
# This is the fixed skeleton. The per-repo content ontology (namespaced by
# first-commit SHA) evolves around it via rdfs:subClassOf / rdfs:subPropertyOf.
#
# Design principles:
#   - Small: ~30 terms. Broad enough to cover any domain.
#   - Abstract: top-level categories, not domain-specific types.
#   - Evolutionary: content ontology subclasses these as it grows.
#   - Fork-compatible: shared namespace means forks speak the same language.
#
# Stack:
#   lex:      — git-lex tool (git objects, commands)
#   lex-o:    — this file (shared upper ontology)
#   {hash}:   — per-repo content ontology (evolved by Repomaster agent)
# =============================================================================

<https://repolex.ai/ontology/lex-upper> a owl:Ontology ;
    rdfs:label "Lex Upper Ontology" ;
    rdfs:comment "Shared upper ontology for git-lex knowledge repos. Provides the fixed categorical skeleton that per-repo content ontologies evolve around." ;
    owl:versionInfo "0.1" .


# =============================================================================
# TOP-LEVEL CATEGORIES
# =============================================================================
# The broadest classification of things that can exist in a knowledge repo.
# Three branches: things that exist, things that are thought, things that
# are written down.
# =============================================================================

lex-o:Thing a owl:Class ;
    rdfs:label "Thing" ;
    rdfs:comment "Root class for all entities in the knowledge graph." .

# --- Concrete: exists in space/time ---

lex-o:Concrete a owl:Class ;
    rdfs:subClassOf lex-o:Thing ;
    rdfs:label "Concrete" ;
    rdfs:comment "Things that exist in space and time: people, organizations, places, objects." .

lex-o:Physical a owl:Class ;
    rdfs:subClassOf lex-o:Concrete ;
    rdfs:label "Physical" ;
    rdfs:comment "Tangible entities: people, organizations, tools, artifacts, places." .

lex-o:Event a owl:Class ;
    rdfs:subClassOf lex-o:Concrete ;
    rdfs:label "Event" ;
    rdfs:comment "Something that happens at a point or period in time: incidents, releases, meetings, battles." .

lex-o:Process a owl:Class ;
    rdfs:subClassOf lex-o:Concrete ;
    rdfs:label "Process" ;
    rdfs:comment "An ongoing activity or workflow: migrations, reviews, evolutions." .

# --- Abstract: doesn't exist in space/time ---

lex-o:Abstract a owl:Class ;
    rdfs:subClassOf lex-o:Thing ;
    rdfs:label "Abstract" ;
    rdfs:comment "Things that exist as ideas, not in physical space: concepts, patterns, qualities." .

lex-o:Concept a owl:Class ;
    rdfs:subClassOf lex-o:Abstract ;
    rdfs:label "Concept" ;
    rdfs:comment "An idea, principle, pattern, or technique: algorithms, architectures, theories." .

lex-o:Quality a owl:Class ;
    rdfs:subClassOf lex-o:Abstract ;
    rdfs:label "Quality" ;
    rdfs:comment "A property or characteristic: complex, secure, deprecated, efficient." .

# --- Information: representations ---

lex-o:Information a owl:Class ;
    rdfs:subClassOf lex-o:Thing ;
    rdfs:label "Information" ;
    rdfs:comment "Representations of knowledge: documents, decisions, observations." .

lex-o:Document a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Document" ;
    rdfs:comment "A content file in the repo. The primary unit of knowledge. Every .md file is a Document." .

lex-o:Decision a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Decision" ;
    rdfs:comment "A recorded choice with context and rationale. Answers 'why did we do this?'" .

# Note: Observation as a class is replaced by RDF 1.2 quoted triples.
# Instead of creating Observation nodes, annotate triples directly:
#   << :elves lex-o:opposes :orcs >> lex-o:observedBy "agent-a@lex.local" .
# This is cleaner and every fact carries its own provenance.

lex-o:Reference a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Reference" ;
    rdfs:comment "A summary or pointer to external work: papers, articles, specifications." .


# =============================================================================
# CORE RELATIONSHIPS
# =============================================================================
# Generic relationships that content ontology terms subclass.
# The upper ontology provides the direction (supports/opposes/replaces),
# the content ontology provides the specifics (hates, alliedWith, etc.).
# =============================================================================

lex-o:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to" ;
    rdfs:comment "Generic relationship between entities. Content ontology terms should rdfs:subPropertyOf this for discoverability." .

lex-o:supports a owl:ObjectProperty ;
    rdfs:subPropertyOf lex-o:relatedTo ;
    rdfs:label "supports" ;
    rdfs:comment "X supports, agrees with, is allied with, or enables Y." .

lex-o:opposes a owl:ObjectProperty ;
    rdfs:subPropertyOf lex-o:relatedTo ;
    rdfs:label "opposes" ;
    rdfs:comment "X opposes, conflicts with, or is against Y." .

lex-o:replaces a owl:ObjectProperty ;
    rdfs:subPropertyOf lex-o:relatedTo ;
    rdfs:label "replaces" ;
    rdfs:comment "X supersedes, replaces, or deprecates Y." .

lex-o:partOf a owl:ObjectProperty ;
    rdfs:subPropertyOf lex-o:relatedTo ;
    rdfs:label "part of" ;
    rdfs:comment "X is a component, member, or part of Y." .

lex-o:causes a owl:ObjectProperty ;
    rdfs:subPropertyOf lex-o:relatedTo ;
    rdfs:label "causes" ;
    rdfs:comment "X causes, triggers, or leads to Y." .

lex-o:requires a owl:ObjectProperty ;
    rdfs:subPropertyOf lex-o:relatedTo ;
    rdfs:label "requires" ;
    rdfs:comment "X depends on, requires, or needs Y." .


# =============================================================================
# KNOWLEDGE ORGANIZATION (inspired by SKOS)
# =============================================================================
# Hierarchical concept organization. The Repomaster uses these to build
# taxonomies as it discovers patterns in the content.
# =============================================================================

lex-o:broader a owl:ObjectProperty ;
    rdfs:label "broader" ;
    rdfs:comment "X is a broader/more general concept than Y. Used for taxonomy building." .

lex-o:narrower a owl:ObjectProperty ;
    owl:inverseOf lex-o:broader ;
    rdfs:label "narrower" ;
    rdfs:comment "X is a narrower/more specific concept than Y. Inverse of broader." .


# =============================================================================
# GROUNDING: LINKING ENTITIES TO DOCUMENTS
# =============================================================================
# How entities connect to the documents they come from. Uses commit/blob
# references so knowledge survives document deletion.
# =============================================================================

lex-o:mentionedInPath a owl:DatatypeProperty ;
    rdfs:label "mentioned in path" ;
    rdfs:range xsd:string ;
    rdfs:comment "File path where this entity is mentioned. Joins with lex:path in the filetree graph. Multiple values expected." .

lex-o:mentionedInBlob a owl:ObjectProperty ;
    rdfs:label "mentioned in blob" ;
    rdfs:comment "Content-addressed blob URI where this entity was extracted from. Joins with lex:blob in the filetree graph. Used for stale detection — if the blob changes, the extraction needs refreshing." .

lex-o:sourceDocument a owl:DatatypeProperty ;
    rdfs:label "source document" ;
    rdfs:range xsd:string ;
    rdfs:comment "The primary file path this entity was extracted from. Unlike mentionedInPath (which can be many), sourceDocument identifies the canonical origin." .


# =============================================================================
# IDENTITY AND DESCRIPTION
# =============================================================================

lex-o:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Human-readable name for an entity." ;
    rdfs:range xsd:string .

lex-o:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:comment "A longer description or summary of what this entity is." ;
    rdfs:range xsd:string .

lex-o:alias a owl:DatatypeProperty ;
    rdfs:label "alias" ;
    rdfs:comment "Alternative name or synonym for this entity. An entity can have multiple aliases." ;
    rdfs:range xsd:string .


# =============================================================================
# PROVENANCE: WHO SAID WHAT, WHEN (RDF 1.2 Quoted Triples)
# =============================================================================
# These properties are designed to annotate quoted triples directly.
# Instead of creating reification nodes, every fact carries its provenance:
#
#   << :elves lex-o:opposes :orcs >> lex-o:observedBy "agent-a@lex.local" ;
#       lex-o:confidence 0.9 ;
#       lex-o:observedAt "2026-03-26T10:00:00Z"^^xsd:dateTime ;
#       lex-o:observedInCommit <commit/abc123> ;
#       lex-o:sourceDocument <commit/abc123/notes/middle-earth-factions.md> .
#
# This enables multi-agent knowledge: two agents can assert contradictory
# facts, and you can see who said what, when, with what confidence.
#
# Query example (SPARQL-star):
#   SELECT ?who ?conf WHERE {
#       << :elves lex-o:opposes :orcs >> lex-o:observedBy ?who ;
#           lex-o:confidence ?conf .
#   }
# =============================================================================

lex-o:observedBy a owl:DatatypeProperty ;
    rdfs:label "observed by" ;
    rdfs:comment "The agent (by git author email) that recorded this fact. Applied to quoted triples via RDF 1.2." ;
    rdfs:range xsd:string .

lex-o:observedAt a owl:DatatypeProperty ;
    rdfs:label "observed at" ;
    rdfs:comment "When this fact was recorded (ISO 8601 datetime). Applied to quoted triples via RDF 1.2." ;
    rdfs:range xsd:dateTime .

lex-o:observedInCommit a owl:ObjectProperty ;
    rdfs:label "observed in commit" ;
    rdfs:comment "The git commit where this fact was first recorded. Immutable provenance anchor. Applied to quoted triples via RDF 1.2." .

lex-o:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:comment "Agent's confidence in this fact, 0.0 to 1.0. Applied to quoted triples via RDF 1.2. Optional." ;
    rdfs:range xsd:decimal .
